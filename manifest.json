{
  "manifest_version": 3,
  "name": "CSS Atlas",
  "version": "0.1.0",
  "description": "Analyze classes, selectors, pseudo-elements, and CSS tokens.",
  "permissions": ["activeTab", "scripting"],

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
	"64": "icons/icon64.png",
    "128": "icons/icon128.png",
	"256": "icons/icon256.png"
  },

  "action": {
    "default_popup": "popup.html"
  }
}